{
  "name": "foobarjs-ecommerce-app",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "foobarjs-ecommerce-app",
      "dependencies": {
        "@foobarjs/cli": "file:../framework/foobar",
        "@foobarjs/framework": "file:../framework/foobarjs"
      },
      "engines": {
        "node": ">=24.17.0"
      }
    },
    "../framework/foobar": {
      "name": "@foobarjs/cli",
      "version": "0.1.0-beta.0",
      "dependencies": {
        "@foobarjs/framework": "^0.1.0-beta.0"
      },
      "bin": {
        "foobar": "bin/foobar.js"
      },
      "engines": {
        "node": ">=24.17.0"
      }
    },
    "../framework/foobarjs": {
      "name": "@foobarjs/framework",
      "version": "0.1.0-beta.0",
      "engines": {
        "node": ">=24.17.0"
      }
    },
    "node_modules/@foobarjs/cli": {
      "resolved": "../framework/foobar",
      "link": true
    },
    "node_modules/@foobarjs/framework": {
      "resolved": "../framework/foobarjs",
      "link": true
    }
  }
}
