# Application
APP_NAME=Foobar Shop
APP_URL=http://localhost:3000
PORT=3000
NODE_ENV=development
APP_DEBUG=true
APP_SECRET=

# Logging
LOG_LEVEL=info
LOG_FILE=

# Database
DB_CONNECTION=sqlite
DB_DATABASE=foobar.db

# Session
SESSION_DRIVER=cookie

# Mail
MAIL_DRIVER=log
MAIL_FROM=hello@example.com
MAIL_HOST=localhost
MAIL_PORT=1025

# Queue
QUEUE_CONNECTION=sync

# Cache
CACHE_STORE=memory

# Redis (only needed if using cache/queue/notifications/realtime with redis)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Realtime (WebSockets)
REALTIME_ENABLED=true
REALTIME_PATH=/ws
REALTIME_REDIS_BROADCAST=false
